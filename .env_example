TIMESCALE_HOST=timescaledb
TIMESCALE_USER=<your_timescale_user>
TIMESCALE_PASSWORD='<your_timescale_password>'  # Guillemets simples obligatoires si le mot de passe contient ! @ ? &
TIMESCALE_PORT=5432
TIMESCALE_NAME=noise_map

POSTGRES_DB=noise_map
POSTGRES_USER=<your_timescale_user>
POSTGRES_PASSWORD='<your_timescale_password>'   # Identique à TIMESCALE_PASSWORD

PGADMIN_DEFAULT_EMAIL=<your_pgadmin_user@mail>
PGADMIN_DEFAULT_PASSWORD=<your_pgadmin_password>

# Carte par défaut — OBLIGATOIRE (seule variable nécessaire si vous ne voulez pas le sélecteur de style)
VITE_MAPTILER_DEFAULT_MAP=https://api.maptiler.com/maps/<your_map_id>/style.json?key=<your_maptiler_api_key>

# Cartes optionnelles — si renseignées, activent le sélecteur de style (2 cartes = 2 boutons, 3 cartes = 3 boutons)
VITE_MAPTILER_LIGHT_MAP=https://api.maptiler.com/maps/<your_light_map_id>/style.json?key=<your_maptiler_api_key>
VITE_MAPTILER_DARK_MAP=https://api.maptiler.com/maps/<your_dark_map_id>/style.json?key=<your_maptiler_api_key>

TOMTOM_API_KEY=<your_tomtom_api_key>

VITE_API_URL=http://localhost:8000 <ou_http://ip_de_votre_vm:8000>

# CORS_ORIGINS doit être l'URL exacte depuis laquelle le navigateur envoie ses requêtes
CORS_ORIGINS=http://localhost:3000 <ou_http://ip_de_votre_vm:3000>

# Activer les logs de performance frontend (false par défaut)
VITE_DEBUG_PERF=false

# Activer /docs et /redoc FastAPI (true en dev, false en prod)
ENABLE_DOCS=true

